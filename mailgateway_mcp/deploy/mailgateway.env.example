# Copy this file to /opt/mailgateway/env/mailgateway.env on the VM
# and replace the example values with the real deployment settings.

MAILGATEWAY_PACKAGE_VERSION=0.1.1.dev0

MAILGATEWAY_SERVER_HOST=0.0.0.0
MAILGATEWAY_SERVER_PORT=8025
MAILGATEWAY_SERVER_PATH=/mcp

MAILGATEWAY_SMTP_HOST=smtp.example.com
MAILGATEWAY_SMTP_PORT=587
MAILGATEWAY_SMTP_AUTHENTICATE=true
MAILGATEWAY_SMTP_USERNAME=bot@example.com
MAILGATEWAY_SMTP_PASSWORD=replace-me
MAILGATEWAY_SMTP_FROM_EMAIL=bot@example.com
MAILGATEWAY_SMTP_FROM_NAME=MailGateway
MAILGATEWAY_SMTP_TLS=starttls
MAILGATEWAY_SMTP_VERIFY_PEER=true
MAILGATEWAY_SMTP_TIMEOUT_SECONDS=30.0
